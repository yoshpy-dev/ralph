#!/usr/bin/env sh
set -eu

# ralph — CLI wrapper for Ralph Loop autonomous development pipeline
#
# Subcommands:
#   plan     Open a planning session (delegates to /plan skill)
#   run      Execute the pipeline (delegates to ralph-pipeline.sh or ralph-orchestrator.sh)
#   status   Show pipeline/orchestrator progress
#   abort    Safely stop and clean up pipeline state

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
. "${SCRIPT_DIR}/ralph-config.sh"

LOOP_DIR=".harness/state/loop"
PIPELINE_DIR=".harness/state/pipeline"
ORCH_STATE=".harness/state/orchestrator"
ARCHIVE_DIR=".harness/state/loop-archive"
WORKTREE_BASE=".claude/worktrees"
EVIDENCE_DIR="docs/evidence"

ts() { date -u '+%Y-%m-%dT%H:%M:%SZ'; }
ts_file() { date -u '+%Y-%m-%d-%H%M%S'; }
log() { printf '[%s] %s\n' "$(ts)" "$*"; }
log_error() { printf '[%s] ERROR: %s\n' "$(ts)" "$*" >&2; }

print_usage() {
  cat <<'USAGE'
ralph — autonomous development pipeline CLI

Usage: ralph <command> [options]

Commands:
  plan                       Start a planning session
  run [options]              Execute the orchestrator (parallel slices)
  status [options]           Show current pipeline progress
  retry <slice-name>         Retry a failed/stuck slice via orchestrator
  abort [--slice <name>]     Safely stop and clean up

Run Options:
  --plan <path>              Plan directory (auto-detected from docs/plans/active/ if omitted)
  --max-iterations N         Total iteration cap (default: 20)
  --max-parallel N           Max concurrent slices (default: 4)
  --preflight                Run capability probe only
  --resume                   Resume from existing checkpoint
  --dry-run                  Show what would run without executing
  --unified-pr               Create a unified PR from integration branch

Abort Options:
  --slice <name>             Abort a specific slice only
  --keep-state               Archive state but don't delete worktrees

Status Options:
  --json                     Output machine-readable JSON
  --watch                    Auto-refresh display (Ctrl+C to stop)
  --interval N               Refresh interval in seconds (default: 5, requires --watch)
  --no-color                 Disable ANSI color codes
  --no-tui                   Force table output even when TUI binary is available

Examples:
  ralph plan
  ralph run --plan docs/plans/active/2026-01-01-my-feature/ --unified-pr
  ralph run --dry-run
  ralph status
  ralph status --json
  ralph status --watch --interval 3
  ralph retry my-slice
  ralph abort
USAGE
}

usage() {
  print_usage
  exit 1
}

# ═══════════════════════════════════════════════════════════════════
# Subcommand: plan
# ═══════════════════════════════════════════════════════════════════

cmd_plan() {
  log "Starting planning session..."
  log "Use /plan in Claude Code to create or update a plan."
  log "Active plans: docs/plans/active/"
  echo ""
  ls -1 docs/plans/active/*.md 2>/dev/null || echo "  (no active plans)"
}

# ═══════════════════════════════════════════════════════════════════
# Subcommand: run
# ═══════════════════════════════════════════════════════════════════

cmd_run() {
  _plan=""
  _extra_args=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --plan)           shift; _plan="${1:?requires a file path}" ;;
      --max-iterations|--max-parallel|--max-inner-cycles|--max-outer-cycles|--max-repair-attempts)
        _flag="$1"; shift; _extra_args="${_extra_args} ${_flag} ${1:?requires a number}" ;;
      --preflight|--resume|--dry-run|--unified-pr)
        _extra_args="${_extra_args} $1" ;;
      *)
        echo "Unknown run option: $1"; exit 1 ;;
    esac
    shift
  done

  # Auto-detect plan if not specified
  if [ -z "$_plan" ]; then
    # Check for directory-based plans (newest by modification time)
    _plan="$(find docs/plans/active -maxdepth 1 -type d ! -name active 2>/dev/null | while read -r d; do
      if [ -f "${d}/_manifest.md" ]; then echo "$d"; fi
    done | head -1 || true)"
    if [ -z "$_plan" ]; then
      echo "Error: no directory-based plan found. Create one with './scripts/new-ralph-plan.sh <slug>' or specify --plan <directory>"
      exit 1
    fi
    log "Auto-detected plan: ${_plan}"
  fi

  if [ ! -d "$_plan" ]; then
    echo "Error: Ralph Loop requires a directory-based plan: ${_plan}"
    echo "Create one with: ./scripts/new-ralph-plan.sh <slug> [issue] [slice-count]"
    exit 1
  fi

  log "Running orchestrator (multi-worktree) mode..."
  # shellcheck disable=SC2086
  exec "${SCRIPT_DIR}/ralph-orchestrator.sh" --plan "$_plan" ${_extra_args}
}

# ═══════════════════════════════════════════════════════════════════
# Subcommand: status
# ═══════════════════════════════════════════════════════════════════

cmd_status() {
  _json_mode=0
  _watch_mode=0
  _watch_interval=5
  _no_tui=0
  STATUS_NO_COLOR=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --json)      _json_mode=1 ;;
      --watch)     _watch_mode=1 ;;
      --interval)  shift; _watch_interval="${1:?requires a number}" ;;
      --no-color)  STATUS_NO_COLOR=1 ;;
      --no-tui)    _no_tui=1 ;;
      *)           echo "Unknown status option: $1"; exit 1 ;;
    esac
    shift
  done

  export STATUS_NO_COLOR

  # JSON mode always uses existing renderer (no TUI)
  if [ "$_json_mode" -eq 1 ]; then
    . "${SCRIPT_DIR}/ralph-status-helpers.sh"
    detect_color
    if [ "$_watch_mode" -eq 1 ]; then
      trap 'printf "\n"; exit 0' INT
      while true; do
        clear
        _render_json "$ORCH_STATE" "$WORKTREE_BASE"
        sleep "$_watch_interval"
      done
    else
      _render_json "$ORCH_STATE" "$WORKTREE_BASE"
    fi
    return
  fi

  # TUI mode: TTY + binary exists + not --no-tui + not outdated
  _tui_bin="${SCRIPT_DIR}/../bin/ralph-tui"
  if [ "$_no_tui" -eq 0 ] && [ -t 1 ] && [ -x "$_tui_bin" ]; then
    # Check if binary is older than source
    _newest_src="$(find "${SCRIPT_DIR}/../cmd" "${SCRIPT_DIR}/../internal" -name '*.go' -newer "$_tui_bin" 2>/dev/null | head -1)"
    if [ -n "$_newest_src" ]; then
      echo "Warning: bin/ralph-tui is outdated. Run scripts/build-tui.sh to rebuild." >&2
      # Fall through to table output
    else
      if [ "$_watch_mode" -eq 1 ]; then
        log "Note: --watch is ignored in TUI mode (TUI auto-refreshes)."
      fi
      # Auto-detect plan dir for dependency graph
      _plan_dir="$(find docs/plans/active -maxdepth 1 -type d ! -name active 2>/dev/null | while read -r d; do
        if [ -f "${d}/_manifest.md" ]; then echo "$d"; fi
      done | head -1 || true)"
      _plan_args=""
      if [ -n "$_plan_dir" ]; then
        _plan_args="--plan-dir ${_plan_dir}"
      fi
      # shellcheck disable=SC2086
      exec "$_tui_bin" --orch-dir "$ORCH_STATE" --worktree-base "$WORKTREE_BASE" $_plan_args
    fi
  fi

  # Table output (fallback)
  . "${SCRIPT_DIR}/ralph-status-helpers.sh"
  detect_color

  if [ "$_watch_mode" -eq 1 ]; then
    trap 'printf "\n"; exit 0' INT
    while true; do
      clear
      _render_table "$ORCH_STATE" "$WORKTREE_BASE"
      printf '\n%bAuto-refresh every %ds. Press Ctrl+C to stop.%b\n' "$C_DIM" "$_watch_interval" "$C_RESET"
      sleep "$_watch_interval"
    done
  else
    _render_table "$ORCH_STATE" "$WORKTREE_BASE"
  fi
}

# ═══════════════════════════════════════════════════════════════════
# Subcommand: retry
# ═══════════════════════════════════════════════════════════════════

cmd_retry() {
  if [ $# -eq 0 ]; then
    echo "Usage: ralph retry <slice-name>"
    exit 1
  fi
  _slice="$1"

  log "═══ Ralph Retry: ${_slice} ═══"

  # --- Check slice status file ---
  _status_file="${ORCH_STATE}/slice-${_slice}.status"
  if [ ! -f "$_status_file" ]; then
    log_error "No status file for slice '${_slice}'. Check the name and try again."
    exit 1
  fi

  _current_status="$(cat "$_status_file" 2>/dev/null || echo "")"
  case "$_current_status" in
    failed|stuck|repair_limit|max_retries|config_error|timeout|gh_unavailable)
      log "Slice '${_slice}' is in status '${_current_status}' — eligible for retry."
      ;;
    running)
      log_error "Slice '${_slice}' is currently running. Abort it first if you want to restart."
      exit 1
      ;;
    complete)
      log_error "Slice '${_slice}' is already complete. Nothing to retry."
      exit 1
      ;;
    pending)
      log_error "Slice '${_slice}' is pending. It will be scheduled automatically."
      exit 1
      ;;
    *)
      log_error "Slice '${_slice}' has unexpected status '${_current_status}'."
      exit 1
      ;;
  esac

  # --- Check orchestrator is running ---
  _orch_json="${ORCH_STATE}/orchestrator.json"
  if [ ! -f "$_orch_json" ]; then
    log_error "No orchestrator state found. Is the orchestrator running?"
    exit 1
  fi

  # --- Parallel limit check ---
  _running_count=0
  for sf in "${ORCH_STATE}"/slice-*.status; do
    [ -f "$sf" ] || continue
    _s="$(cat "$sf" 2>/dev/null || echo "")"
    if [ "$_s" = "running" ]; then
      _running_count=$((_running_count + 1))
    fi
  done

  _max_parallel=4
  if command -v jq >/dev/null 2>&1 && [ -f "$_orch_json" ]; then
    _mp="$(jq -r '.max_parallel // 4' "$_orch_json" 2>/dev/null || echo "4")"
    _max_parallel="${_mp:-4}"
  fi

  if [ "$_running_count" -ge "$_max_parallel" ]; then
    log_error "Already ${_running_count} slices running (max: ${_max_parallel}). Wait for one to finish."
    exit 1
  fi

  # --- Locate worktree ---
  _wt_path="${WORKTREE_BASE}/${_slice}"
  if [ ! -d "$_wt_path" ]; then
    log_error "Worktree not found: ${_wt_path}"
    exit 1
  fi

  # --- Update status and reset timeout baseline ---
  echo "running" > "$_status_file"
  # Reset start time so the orchestrator's timeout check uses the retry time, not the original.
  date -u +"%Y-%m-%dT%H:%M:%SZ" > "${ORCH_STATE}/slice-${_slice}.started"
  log "Updated status to 'running' and reset start time."

  # Launch pipeline in background
  (
    cd "$_wt_path"
    "${SCRIPT_DIR}/ralph-pipeline.sh" --resume 2>&1
  ) &
  _pid=$!

  # Record PID
  echo "$_pid" > "${ORCH_STATE}/slice-${_slice}.pid"
  log "Pipeline started (PID: ${_pid}) in worktree: ${_wt_path}"
  log "Monitor with: ralph status"
}

# ═══════════════════════════════════════════════════════════════════
# Subcommand: abort
# ═══════════════════════════════════════════════════════════════════

cmd_abort() {
  _target_slice=""
  _keep_state=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --slice) shift; _target_slice="${1:?requires slice name}" ;;
      --keep-state) _keep_state=1 ;;
      *) echo "Unknown abort option: $1"; exit 1 ;;
    esac
    shift
  done

  log "═══ Ralph Abort ═══"

  _audit_file="${EVIDENCE_DIR}/abort-audit-$(ts_file).json"
  mkdir -p "$EVIDENCE_DIR"

  _archived_state=""
  _worktrees_removed=""
  _checkpoint_snapshot="{}"

  # --- Kill running pipeline processes ---
  _killed_pids=""
  if [ -n "$_target_slice" ]; then
    _pid_file="${ORCH_STATE}/slice-${_target_slice}.pid"
    if [ -f "$_pid_file" ]; then
      _pid="$(cat "$_pid_file")"
      if kill -0 "$_pid" 2>/dev/null; then
        kill "$_pid" 2>/dev/null || true
        _killed_pids="$_pid"
        log "Killed slice ${_target_slice} (PID: ${_pid})"
      fi
    fi
  else
    # Kill all running slice PIDs
    for pf in "${ORCH_STATE}"/slice-*.pid; do
      [ -f "$pf" ] || continue
      _pid="$(cat "$pf")"
      if kill -0 "$_pid" 2>/dev/null; then
        kill "$_pid" 2>/dev/null || true
        _killed_pids="${_killed_pids:+${_killed_pids}, }${_pid}"
        log "Killed PID: ${_pid}"
      fi
    done
  fi

  # --- Snapshot checkpoint before archiving ---
  if [ -f "${PIPELINE_DIR}/checkpoint.json" ]; then
    _checkpoint_snapshot="$(cat "${PIPELINE_DIR}/checkpoint.json")"
  fi

  # --- Archive state ---
  _archive_ts="$(ts_file)"
  _archive_dest="${ARCHIVE_DIR}/${_archive_ts}"

  if [ -n "$_target_slice" ]; then
    # Archive only the target slice's worktree state
    _wt_path="${WORKTREE_BASE}/${_target_slice}"
    if [ -d "${_wt_path}/.harness/state" ]; then
      mkdir -p "${_archive_dest}/slice-${_target_slice}"
      cp -r "${_wt_path}/.harness/state/." "${_archive_dest}/slice-${_target_slice}/"
      _archived_state="${_archive_dest}/slice-${_target_slice}"
      log "Archived slice state to ${_archived_state}"
    fi
  else
    # Archive all state
    if [ -d "$LOOP_DIR" ]; then
      mkdir -p "${_archive_dest}/loop"
      cp -r "${LOOP_DIR}/." "${_archive_dest}/loop/"
      log "Archived loop state"
    fi
    if [ -d "$PIPELINE_DIR" ]; then
      mkdir -p "${_archive_dest}/pipeline"
      cp -r "${PIPELINE_DIR}/." "${_archive_dest}/pipeline/"
      log "Archived pipeline state"
    fi
    if [ -d "$ORCH_STATE" ]; then
      mkdir -p "${_archive_dest}/orchestrator"
      cp -r "${ORCH_STATE}/." "${_archive_dest}/orchestrator/"
      log "Archived orchestrator state"
    fi
    _archived_state="$_archive_dest"
  fi

  # --- Remove worktrees ---
  if [ "$_keep_state" -eq 0 ]; then
    if [ -n "$_target_slice" ]; then
      _wt_path="${WORKTREE_BASE}/${_target_slice}"
      if [ -d "$_wt_path" ]; then
        git worktree remove "$_wt_path" --force 2>/dev/null || true
        _worktrees_removed="\"${_wt_path}\""
        log "Removed worktree: ${_wt_path}"
      fi
    else
      # Remove all ralph worktrees (use temp file to avoid pipe-subshell variable loss)
      _wt_list=""
      _wt_tmp="$(mktemp)"
      git worktree list 2>/dev/null | grep "${WORKTREE_BASE}" > "$_wt_tmp" || true
      while IFS=' ' read -r wpath _rest; do
        git worktree remove "$wpath" --force 2>/dev/null || true
        _wt_list="${_wt_list:+${_wt_list}, }\"${wpath}\""
        log "Removed worktree: ${wpath}"
      done < "$_wt_tmp"
      rm -f "$_wt_tmp"
      _worktrees_removed="[${_wt_list}]"
    fi

    # Clean up state directories (non-archived)
    if [ -z "$_target_slice" ]; then
      rm -rf "$PIPELINE_DIR" "$ORCH_STATE"
      log "Cleaned pipeline and orchestrator state"
    fi
  fi

  # --- Write audit log ---
  cat > "$_audit_file" <<AUDIT_JSON
{
  "timestamp": "$(ts)",
  "reason": "user_abort",
  "target_slice": $([ -n "$_target_slice" ] && echo "\"${_target_slice}\"" || echo "null"),
  "killed_pids": "$(echo "${_killed_pids}" | tr -d '\n')",
  "archived_state": "$(echo "${_archived_state}" | tr -d '\n')",
  "worktrees_removed": $(echo "${_worktrees_removed:-[]}" | tr -d '\n'),
  "keep_state": $([ "$_keep_state" -eq 1 ] && echo true || echo false),
  "checkpoint_at_abort": ${_checkpoint_snapshot}
}
AUDIT_JSON

  log "Audit log written to: ${_audit_file}"
  log ""
  log "Abort complete."
  if [ -n "$_archived_state" ]; then
    log "State archived to: ${_archived_state}"
    log "To resume later: ralph run --resume"
  fi
}

# ═══════════════════════════════════════════════════════════════════
# Main dispatcher
# ═══════════════════════════════════════════════════════════════════

if [ $# -eq 0 ]; then
  usage
fi

_command="$1"
shift

case "$_command" in
  plan)   cmd_plan "$@" ;;
  run)    cmd_run "$@" ;;
  status) cmd_status "$@" ;;
  retry)  cmd_retry "$@" ;;
  abort)  cmd_abort "$@" ;;
  -h|--help) print_usage; exit 0 ;;
  *)      echo "Unknown command: ${_command}"; usage ;;
esac
